# =============================================
# .claudeignore — Projeto Delphi
# Gerado automaticamente pelo plugin delphi-dev
# =============================================

# --- Arquivos compilados e binarios ---
*.dcu
*.exe
*.dll
*.bpl
*.dcp
*.rsm
*.so
*.dylib
*.apk
*.ipa

# --- Recursos compilados ---
*.res
*.dres

# --- Configuracao e metadados de IDE ---
*.dproj
*.dof
*.cfg
*.local
*.identcache
*.projdata
*.tvsconfig
*.dsk

# --- Mapas e debug ---
*.map
*.drc
*.jdbg

# --- Arquivos temporarios ---
*.~*
*.bak
*.tmp
*.log

# --- Logs e saidas de build via .bat ---
build_log.txt
test_log.txt
compile_output.txt

# --- Saidas de compilacao por plataforma ---
Win32/
Win64/
Android/
Android64/
iOSDevice32/
iOSDevice64/
iOSSimulator/
OSX64/
OSXARM64/
Linux64/

# --- Historico e backup de IDE ---
__history/
__recovery/

# --- Outros ---
*.svn/
.git/
node_modules/
